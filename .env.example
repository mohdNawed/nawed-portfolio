RECIPIENT_EMAIL=your-inbox@gmail.com
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Nawed Dev <onboarding@resend.dev>

# Optional Gmail fallback when RESEND_API_KEY is omitted.
MAIL_USER=your-gmail-address@gmail.com
MAIL_PASS=your-gmail-app-password
CORS_ORIGIN=https://naweddev.com,https://nawed-portfolio-mohdnaweds-projects.vercel.app
JWT_SECRET=change-this-to-a-long-random-secret
ADMIN_EMAILS=your-admin-email@gmail.com

# Supabase message storage. Keep the secret key server-side only.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your-supabase-secret-key
# Legacy projects can use SUPABASE_SERVICE_ROLE_KEY instead.
SUPABASE_SERVICE_ROLE_KEY=

# Optional fallback while Supabase is not configured.
MONGO_URI=
MONGO_DB_NAME=portfolio
